---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | Indiefluence" description="The page you are looking for is not available.">
  <section class="bg-white pb-10 pt-32 font-serif min-h-screen">
    <div class="container mx-auto px-4">
      <div class="flex justify-center">
        <div class="w-full text-center">
          {/* 404 Background Image Section */}
          <div
            class="bg-center bg-no-repeat h-[400px] w-full"
            style={{
              backgroundImage: "url(https://cdn.dribbble.com/users/285475/screenshots/2083086/dribbble_1.gif)",
            }}
          >
            <h1 class="text-[80px] text-center">404</h1>
          </div>

          {/* Content Section */}
          <div class="-mt-[50px] flex flex-col items-center">
            <h3 class="text-[32px]">Look like you're lost</h3>
            <p class="text-lg text-gray-600 mb-6">the page you are looking for not available!</p>

            <a
              href="/"
              class="inline-block px-5 py-3 bg-[#39ac31] text-white rounded hover:bg-[#2d8a26] transition-colors duration-300"
            >
              Go to Home
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
