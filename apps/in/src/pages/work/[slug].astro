---
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Counter from "@/components/site/counter";
import CtaBand from "@/components/site/cta-band.astro";
import { Container } from "@/components/site/primitives";
import Reveal from "@/components/site/reveal";

export async function getStaticPaths() {
  const workEntries = await getCollection('work');
  return workEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const data = entry.data;
const { Content } = await render(entry);
---

<Layout title={`${data.title} — ${data.client ?? "Case study"}`} description={data.description}>
  <section class="pt-[clamp(7rem,14vw,10rem)]">
    <Container>
      <a
        href="/work"
        class="group mb-8 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.1em] text-muted-foreground transition-colors duration-300 hover:text-brand"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          class="transition-transform duration-400 ease-smooth group-hover:-translate-x-1"
        >
          <path d="M19 12H5M11 19l-7-7 7-7" />
        </svg>
        All case studies
      </a>

      <div class="mb-4 flex flex-wrap gap-2">
        {data.tags.map((tag: string) => (
          <span
            class="rounded-[6px] border px-2.5 py-1.5 font-mono text-xs uppercase tracking-[0.1em] text-brand"
          >
            {tag}
          </span>
        ))}
      </div>

      <h1 class="my-5 max-w-[16ch] text-5xl leading-[0.98] tracking-[-0.03em]">{data.title}</h1>
      <p class="mb-10 font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground">
        {data.client} · {data.sector}
      </p>

      <div
        class="relative mb-[clamp(2.5rem,6vw,4rem)] grid aspect-[21/9] place-items-center overflow-hidden rounded-[22px] text-white after:absolute after:inset-0 after:bg-[radial-gradient(90%_120%_at_20%_0%,rgba(255,255,255,.18),transparent_55%)] after:content-['']"
        style={{ background: `linear-gradient(140deg, ${data.gradient[0]}, ${data.gradient[1]})` }}
      >
        <span class="z-1 font-display text-[clamp(2rem,7vw,4rem)] font-semibold tracking-[-0.03em]">
          {data.client}
        </span>
      </div>

      <div class="mb-[clamp(2.5rem,6vw,4rem)] grid grid-cols-2 gap-px overflow-hidden rounded-[22px] border bg-border md:grid-cols-4">
        {data.metrics.map(([value, label]: [string, string]) => (
          <div class="grid gap-1 bg-card p-[clamp(1.3rem,3vw,2rem)]">
            <Counter
              value={value}
              className="font-display text-[clamp(1.8rem,5vw,2.8rem)] leading-none font-semibold tracking-[-0.02em] text-brand"
              client:visible
            />
            <span class="font-mono text-xs uppercase tracking-[0.1em] text-muted-foreground">{label}</span>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <section class="pb-[clamp(4.5rem,10vw,8.5rem)]">
    <Container>
      <article class="mx-auto max-w-[760px] prose prose-h2:mt-[clamp(2.2rem,5vw,3.2rem)] prose-h2:mb-4 prose-h2:text-3xl prose-h2:leading-[1.05] prose-p:mb-4 prose-p:text-base prose-p:leading-relaxed prose-p:text-[#3A4056]">
        <Content />
      </article>

      {data.quote && (
        <Reveal className="mx-auto mt-[clamp(2.5rem,6vw,4rem)] max-w-[760px]" client:visible>
          <blockquote class="border-l-2 border-amber py-1.5 pl-7">
            <p class="font-display text-[clamp(1.3rem,3.4vw,1.8rem)] leading-[1.25] font-medium tracking-[-0.02em]">
              “{data.quote.text}”
            </p>
            <cite class="mt-3 block font-mono text-xs uppercase not-italic tracking-[0.1em] text-muted-foreground">
              {data.quote.cite}
            </cite>
          </blockquote>
        </Reveal>
      )}

      <Reveal className="mt-[clamp(3.5rem,8vw,6rem)]" client:visible>
        <CtaBand
          eyebrow="Next step"
          lead="Tell us about your brand and your goal. We'll come back with a clear view of how we'd approach it."
        >
          <Fragment slot="title">Want an outcome like this one?</Fragment>
        </CtaBand>
      </Reveal>
    </Container>
  </section>
</Layout>
