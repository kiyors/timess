---
import { CLIENT_LOGOS } from "@/data/site";
---

<div class="grid grid-cols-2 gap-px overflow-hidden rounded-[22px] border bg-border sm:grid-cols-3 md:grid-cols-5">
  {CLIENT_LOGOS.map((logo) => (
    <div class="grid aspect-[2.4/1] place-items-center bg-paper p-6 transition-colors duration-400 ease-smooth hover:bg-card">
      <div class="relative h-[46px] w-[min(140px,78%)]">
        <img
          src={logo.src}
          alt={logo.name}
          sizes="140px"
          loading="lazy"
          class="h-full w-full object-contain opacity-60 grayscale transition-[filter,opacity] duration-400 ease-smooth hover:opacity-100 hover:grayscale-0"
        />
      </div>
    </div>
  ))}
</div>
