<section class="w-full border-b border-black flex flex-col py-8 px-4">
  <div class="text-center mb-8">
    <h2 class="font-sans font-black text-4xl md:text-5xl uppercase tracking-widest">
      CLASSIFIED ADVERTISEMENTS
    </h2>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Classified 1 -->
    <div class="border-4 border-black p-4 flex flex-col items-center bg-[#f4f4ea] bg-[url('/assets/DFovMU4gpTIHYNXz6zh17SR5OM.png')]">
      <h3 class="font-serif text-xl italic mb-4">House of Aravat</h3>
      <img src="/assets/gM3QWAKasiUgV95mnFcbv3U2wo.png" alt="House of Aravat lady" class="w-full object-contain mb-4 mix-blend-multiply" />
      <p class="font-sans text-[10px] text-center">House of Fine Jewels & Ornaments</p>
    </div>
    
    <!-- Classified 2 -->
    <div class="border-4 border-black p-4 flex flex-col items-center bg-[#f4f4ea] bg-[url('/assets/DFovMU4gpTIHYNXz6zh17SR5OM.png')]">
      <h3 class="font-display text-2xl mb-4">Electronic Garage</h3>
      <img src="/assets/up8otoXOAHCL1zPivbNVo0oAKg.png" alt="Electronic Garage TV" class="w-full object-contain mb-4 mix-blend-multiply" />
      <h4 class="font-sans font-bold text-sm tracking-widest uppercase mt-4 mb-2">INDIEFLUENCE GARAGE</h4>
      <p class="font-sans text-[10px] text-center">Dependable Craftmanship Punctual Delivery</p>
    </div>
    
    <!-- Classified 3 -->
    <div class="border-4 border-black p-4 flex flex-col items-center bg-[#f4f4ea] bg-[url('/assets/DFovMU4gpTIHYNXz6zh17SR5OM.png')]">
      <h3 class="font-serif text-xl italic mb-4">House of Aravat</h3>
      <img src="/assets/ZTY3TD2QvNI344hJigDszBDAhyo.png" alt="House of Aravat lady" class="w-full object-contain mb-4 mix-blend-multiply" />
      <p class="font-sans text-[10px] text-center">House of Fine Jewels & Ornaments</p>
    </div>
  </div>
</section>
