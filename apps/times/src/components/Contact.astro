---
---
<section class="w-full border-b border-black flex flex-col pt-12 pb-12 px-12 bg-[#f4f4ea]" id="contact">
  <div class="text-center mb-8">
    <h2 class="font-sans font-black text-4xl md:text-5xl uppercase tracking-widest">
      WANNA GET IN TOUCH?
    </h2>
  </div>
  
  <div class="border-2 border-black flex flex-col md:flex-row bg-[#f4f4ea] relative">
    <!-- Postcard Left -->
    <div class="w-full md:w-1/2 p-8 border-b md:border-b-0 md:border-r border-black border-dashed flex flex-col relative">
      <h3 class="font-sans font-bold text-sm tracking-widest uppercase mb-8">SEND YOURSELF A POSTCARD</h3>
      <div class="flex-1 flex flex-col">
        <label class="font-sans text-xs mb-2">Inquiry :</label>
        <textarea class="w-full bg-transparent resize-none h-32 focus:outline-none text-xs font-serif leading-6" style="background-image: repeating-linear-gradient(transparent, transparent 23px, #ccc 23px, #ccc 24px, transparent 24px); line-height: 24px;"></textarea>
      </div>
      <div class="mt-8">
        <button class="border-2 border-black px-6 py-2 font-sans font-bold text-lg uppercase tracking-widest hover:bg-black hover:text-white transition">
          SEND POSTCARD
        </button>
      </div>
    </div>
    
    <!-- Postcard Right -->
    <div class="w-full md:w-1/2 p-8 flex flex-col justify-center relative">
      <!-- Stamp -->
      <div class="absolute top-4 right-4 w-16 h-16">
        <img src="/assets/c3nVyPZ5UXbwbCOmle4EC4rc0.png" alt="Stamp" class="w-full h-full object-contain mix-blend-multiply opacity-50" />
      </div>
      
      <div class="space-y-6 mt-12">
        <div class="flex items-end border-b border-dashed border-black pb-1">
          <label class="font-sans text-xs w-32 shrink-0">From The Desk Of :</label>
          <input type="text" class="w-full bg-transparent focus:outline-none text-xs font-serif px-2" />
        </div>
        <div class="flex items-end border-b border-dashed border-black pb-1">
          <label class="font-sans text-xs w-32 shrink-0">Email :</label>
          <input type="email" class="w-full bg-transparent focus:outline-none text-xs font-serif px-2" />
        </div>
        <div class="flex items-end border-b border-dashed border-black pb-1">
          <label class="font-sans text-xs w-32 shrink-0">Contact Number :</label>
          <input type="tel" class="w-full bg-transparent focus:outline-none text-xs font-serif px-2" />
        </div>
        <div class="flex items-end border-b border-dashed border-black pb-1">
          <label class="font-sans text-xs w-32 shrink-0">Website :</label>
          <input type="url" class="w-full bg-transparent focus:outline-none text-xs font-serif px-2" />
        </div>
      </div>
    </div>
  </div>
</section>
