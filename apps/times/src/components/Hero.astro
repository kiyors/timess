---
---
<section class="w-full flex flex-col md:flex-row border-b border-black">
  <!-- Left Side: Aladdin News -->
  <div class="flex-1 border-r border-black flex flex-col">
    <!-- Cursive Header -->
    <div class="text-center py-4 border-b-2 border-dashed border-[#26498d] mx-4 my-4 relative">
      <h2 class="font-display text-5xl md:text-7xl text-[#26498d] transform -rotate-2">
        ALADDIN NEWS!
      </h2>
    </div>
    
    <!-- Filmstrip Image -->
    <div class="w-full px-4 mb-4">
      <img src="/assets/YYiI4mnPnuHwPB1N4atSyOFGIY.png" alt="Filmstrip of CEO" class="w-full object-cover border border-black p-1" />
    </div>
    
    <!-- Content -->
    <div class="px-4 pb-4">
      <p class="font-sans font-bold text-lg md:text-xl leading-relaxed mb-4">
        In a development of limited national importance, our Managing Editor has once again consumed excessive caffine and delivered this morning's wisdom.
      </p>
      <p class="font-serif italic text-sm text-gray-700">
        From Ceo's Desk
      </p>
    </div>
  </div>
  
  <!-- Right Side: Get In Touch -->
  <div class="w-full md:w-1/3 flex flex-col items-center justify-center p-8 text-center bg-[#f4f4ea]">
    <img src="/assets/8jBvWhxFrO5QJDv7AfQNtynnUY.png" alt="Rotary Phone" class="w-48 mb-6" />
    <h3 class="font-sans font-black text-2xl uppercase tracking-widest mb-4">
      GET IN TOUCH<br/>WITH US
    </h3>
    <p class="font-sans font-bold text-sm mb-1">+91 98967 42069</p>
    <p class="font-sans font-bold text-sm uppercase mb-6">VENU@INDIEFLUENCE.IN</p>
    <a href="#contact" class="inline-block border border-black bg-transparent px-6 py-2 font-sans font-bold text-xs tracking-widest uppercase hover:bg-black hover:text-white transition">
      Book a meeting
    </a>
  </div>
</section>
