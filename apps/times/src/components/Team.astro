<section class="w-full border-b border-black flex flex-col pt-8 pb-8">
  <div class="text-center mb-12 border-b-2 border-dashed border-gray-400 pb-8 mx-12">
    <h2 class="font-sans font-black text-4xl md:text-5xl uppercase tracking-widest bg-[#f4f4ea] px-8 inline-block -mb-14 relative z-10">
      THE FOUNDING EDITORS
    </h2>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 px-12 mt-6">
    <!-- Venu -->
    <div class="flex flex-col md:flex-row gap-6 items-center">
      <div class="w-48 h-48 border border-black flex-shrink-0">
        <img src="/assets/VsT15PESFQpy2Estch6BVbJA5YQ.png" alt="Venu" class="w-full h-full object-cover mix-blend-multiply" />
      </div>
      <div class="flex flex-col justify-center">
        <p class="font-serif text-[11px] leading-relaxed mb-4 text-justify">
          Venu blends technology, strategy, and human insight to craft purposeful solutions. His work reflects clarity, discipline, and thoughtful design, shaped by years of creative exploration and a deep commitment to meaningful, craftsmanship.
        </p>
        <h3 class="font-sans font-black text-sm tracking-widest uppercase">VENU</h3>
      </div>
    </div>
    
    <!-- Vrinda -->
    <div class="flex flex-col md:flex-row gap-6 items-center">
      <div class="w-48 h-48 border border-black flex-shrink-0">
        <img src="/assets/SeXs2WzZYVIQqJW8ma9hUpzLZQ.png" alt="Vrinda" class="w-full h-full object-cover mix-blend-multiply" />
      </div>
      <div class="flex flex-col justify-center">
        <p class="font-serif text-[11px] leading-relaxed mb-4 text-justify">
          Vrinda unites design, culture, and storytelling to create work that feels both expressive and enduring. Her craft honours handmade detail, elevates creators, and brings thoughtful beauty to every project she touches.
        </p>
        <h3 class="font-sans font-black text-sm tracking-widest uppercase">VRINDA</h3>
      </div>
    </div>
  </div>
</section>
